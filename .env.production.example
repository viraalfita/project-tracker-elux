NEXT_PUBLIC_POCKETBASE_URL=YOUR_POCKETBASE_URL
NEXT_PUBLIC_APP_URL=https://your-app-domain.com

# Server-side only — used by /api/admin/* routes to manage users and invites
# Never prefixed with NEXT_PUBLIC_ so they never reach the browser bundle
PB_ADMIN_EMAIL=YOUR_ADMIN_EMAIL
PB_ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD

# AI parser provider (used by /api/ai/parse)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-5-nano
OPENAI_MAX_TOKENS=180
OPENAI_LOG_RESPONSE=false

# SMTP — used to send informational invite emails via nodemailer (not OTP)
# OTP emails are still sent by PocketBase's built-in mailer
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=YOUR_RESEND_SMTP_PASSWORD
SMTP_FROM=tracker@eluxemang.top
